# Port for the backend server (Default: 8080)
PORT=8080

# Secret key used for signing and verifying JSON Web Tokens (JWT) for authentication
JWT_SECRET=your_super_secret_jwt_key_here

# Connection string for PostgreSQL database (User, Password, Host, Port, DB Name)
# Note: Default postgres port is 5432, but if using project's docker-compose it might be 5433
DATABASE_URL=postgres://lifecap:lifecap_secret@localhost:5433/life_capital?sslmode=disable

# Google Client ID used for Google OAuth2 Login feature
GOOGLE_CLIENT_ID=your_google_client_id_here

# Google Gemini API Key used for Module 0 (AI Onboarding & Profile Extraction)
# Get it here: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash
AI_MAX_OUTPUT_TOKENS=8192

# Groq API Key used as a fallback (100% Free, Llama 3) if Gemini is overloaded
# Get it here: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
